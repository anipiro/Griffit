# Copy this to `.env` if you need to override defaults.
# Recommended: follow the Quick local setup in the README (runs the local emulator):
#   See [README.md](README.md#quick-local-setup-(recommended))

# If you want to use browser mocks instead of Supabase, set:
# VITE_USE_MOCKS=true
VITE_USE_MOCKS=true

# When connecting to a real Supabase project, set the values below (advanced users):
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# Optional: used for redirect after auth
VITE_APP_URL=http://localhost:5173
